{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.viralworks-studio.com" }],
      "destination": "https://viralworks-studio.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "viralworks-studio.vercel.app" }],
      "destination": "https://viralworks-studio.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "viralworks-studio-ludovic0504s-projects.vercel.app" }],
      "destination": "https://viralworks-studio.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "viralworks-studio-ludovic0504-ludovic0504s-projects.vercel.app" }],
      "destination": "https://viralworks-studio.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
