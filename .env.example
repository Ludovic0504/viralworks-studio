############################################
# Supabase Edge Functions (secrets côté Supabase)
############################################
# Ces variables NE SONT PAS lues par Vite.
# Elles doivent être configurées dans Supabase (Function secrets).
#
# Requises par plusieurs fonctions:
SUPABASE_URL=
SUPABASE_ANON_KEY=
SERVICE_ROLE_KEY=
SITE_URL=http://localhost:5173

# Stripe (secrets Supabase — clés SECRÈTES sk_… et whsec_… uniquement)
# Test : STRIPE_MODE=test + STRIPE_SECRET_KEY_TEST + STRIPE_WEBHOOK_SECRET_TEST
# Live : STRIPE_MODE=live + STRIPE_SECRET_KEY_LIVE (+ STRIPE_WEBHOOK_SECRET_LIVE)
# Rétrocompat : STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET
STRIPE_MODE=live
STRIPE_SECRET_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Pipeline vidéo/audio externe (appelé par la fonction `video-postprocess`)
VIDEO_AUDIO_PIPELINE_URL=http://localhost:8788/api/video-postprocess
VIDEO_AUDIO_PIPELINE_TOKEN=

# Hailuo / MiniMax (noms possibles supportés par `hailuo-image` et onglet Hailuo vidéo)
MINIMAX_API_KEY=
HAILUO_API_KEY=
HAILUO_IMAGE_API_KEY=
CleAPI_Hailuo_Image=
CléAPI_Hailuo_Image=

# Vertex AI — Veo 3 (Edge Function `vertex-veo-video`, onglet « Vidéo virale » / VEO3)
# À configurer comme secrets Supabase (Dashboard → Project Settings → Edge Functions → Secrets),
# ou : supabase secrets set NOM=valeur
# Le front n’a besoin que de VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY ; rien de sensible Vertex côté Vite.
#
# Requis :
# - API Vertex AI activée sur le projet GCP ; accès au modèle Veo configuré pour ce projet.
# - Compte de service avec au minimum : Vertex AI User (ou rôle permettant predictLongRunning),
#   + droits d’écriture sur le bucket GCS du préfixe ci-dessous (ex. Storage Object Admin sur le préfixe).
GOOGLE_SERVICE_ACCOUNT_JSON=
# Alias acceptés par la fonction : GCP_SERVICE_ACCOUNT_JSON, VERTEX_AI_SERVICE_ACCOUNT_JSON
# Alternative (secrets séparés, reconnus par vertex-veo-video) :
# GOOGLE_CLIENT_EMAIL=  GOOGLE_PRIVATE_KEY=  GOOGLE_PROJECT_ID=
GOOGLE_CLOUD_PROJECT_ID=
# Alias : GCP_PROJECT_ID, GOOGLE_CLOUD_PROJECT, GOOGLE_PROJECT_ID
# Préfixe GCS des sorties (doit finir par / après normalisation côté serveur), ex. gs://mon-bucket/dossier-veo/
VERTEX_VIDEO_GCS_URI=
# Alias : VERTEX_VEO_OUTPUT_GCS_URI ; ou seulement GCS_BUCKET → gs://<bucket>/veo-output/
# IAM (obligatoire pour Veo) :
# - Sur CE bucket : principal service-<NUMÉRO_PROJET_VERTEX>@gcp-sa-aiplatform.iam.gserviceaccount.com
#   (le NUMÉRO apparaît dans l’erreur API), rôle roles/storage.objectCreator.
#   Même si le bucket est dans un autre projet GCP : les permissions se ajoutent sur le bucket cible.
# - Sur le même bucket : le compte de service des secrets Google (Edge Function) doit pouvoir LIRE les objets
#   (roles/storage.objectViewer) pour signer l’URL de lecture.
# Exemple gcloud (remplace BUCKET et PROJECT_ID du projet qui possède le bucket) :
#   gcloud storage buckets add-iam-policy-binding gs://BUCKET --project=PROJECT_ID --member=serviceAccount:service-194362260482@gcp-sa-aiplatform.iam.gserviceaccount.com --role=roles/storage.objectCreator
# Ou : powershell -File scripts/grant-vertex-veo-bucket-iam.ps1
# Optionnel :
# VERTEX_AI_LOCATION=us-central1
# VERTEX_AI_MODEL_ID=veo-3.0-fast-generate-001

# Optionnel selon fonctions:
OPENAI_API_KEY=

############################################
# Déploiement OVH (FTP) — npm run deploy:ovh-ftp
############################################
# FTP_PASSWORD=          # mot de passe FTP OVH (dans .env.local, jamais committer)
# FTP_HOST=ftp.cluster100.hosting.ovh.net
# FTP_USER=rbaqzyl
# FTP_PORT=21
# FTP_REMOTE_DIR=www     # ou . si la racine web est déjà le répertoire courant après login
# FTP_LOCAL_DIR=dist
# FTP_LIST_ONLY=1        # liste la racine FTP sans upload (pour trouver le bon dossier)
# FTP_VERBOSE=1          # logs FTP détaillés (optionnel)
# FTP_PASSIVE=0          # mode actif PORT (défaut : passif PASV)

